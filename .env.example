# General
COMPOSE_PROJECT_NAME=estadisticas-varias
RESTART_POLICY=unless-stopped

# Image versions. Pin these before leaving the stack unattended.
PROMETHEUS_VERSION=latest
GRAFANA_VERSION=latest
CADVISOR_VERSION=latest
NODE_EXPORTER_VERSION=latest

# Container names
PROMETHEUS_CONTAINER_NAME=observatorio-prometheus
GRAFANA_CONTAINER_NAME=observatorio-grafana
CADVISOR_CONTAINER_NAME=observatorio-cadvisor
NODE_EXPORTER_CONTAINER_NAME=observatorio-node-exporter

# Ports and bind addresses.
# Grafana is the main UI. The exporters default to localhost for safer deployments.
GRAFANA_BIND_ADDRESS=0.0.0.0
GRAFANA_PORT=3030
PROMETHEUS_BIND_ADDRESS=127.0.0.1
PROMETHEUS_PORT=9090
CADVISOR_BIND_ADDRESS=127.0.0.1
CADVISOR_PORT=8085
NODE_EXPORTER_BIND_ADDRESS=127.0.0.1
NODE_EXPORTER_PORT=9100

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CambiaEstaPassword
GRAFANA_DEFAULT_THEME=dark
GRAFANA_ROOT_URL=

# Prometheus
PROMETHEUS_RETENTION=30d
